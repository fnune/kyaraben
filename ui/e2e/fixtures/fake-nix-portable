#!/bin/bash
# Environment variables:
#   FAKE_NIX_FAIL=1        - Simulate build failure
#   FAKE_NIX_SLOW=1        - Add delays to simulate slow builds
#   FAKE_NIX_STORE         - Base path for fake store (required for builds)
#   FAKE_NIX_PROGRESS=1    - Output realistic progress messages

set -e

log() {
  echo "[fake-nix] $*" >&2
}

log "Called with args: $*"

simulate_progress() {
  local pkg="$1"
  if [[ "$FAKE_NIX_PROGRESS" == "1" ]]; then
    echo "evaluating derivation..." >&2
    [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.2 || true

    # Simulate multiple packages for a more realistic progress display
    local packages=("$pkg" "retroarch" "es-de")
    local download_packages=("libretro-bsnes" "libretro-mgba")

    echo "these ${#download_packages[@]} paths will be fetched (45.6 MiB download):" >&2
    for dp in "${download_packages[@]}"; do
      echo "  /nix/store/fake-hash-$dp" >&2
    done
    [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.2 || true

    for dp in "${download_packages[@]}"; do
      echo "copying path '/nix/store/fake-hash-$dp' from 'https://cache.nixos.org'..." >&2
      [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.15 || true
    done

    echo "these ${#packages[@]} derivations will be built:" >&2
    for p in "${packages[@]}"; do
      echo "  /nix/store/fake-hash-$p.drv" >&2
    done
    [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.2 || true

    for p in "${packages[@]}"; do
      echo "building '/nix/store/fake-hash-$p.drv'..." >&2
      echo "$p> unpacking sources" >&2
      [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.1 || true
      echo "$p> configuring" >&2
      [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.1 || true
      echo "$p> building" >&2
      [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.15 || true
      echo "$p> installing" >&2
      [[ "$FAKE_NIX_SLOW" == "1" ]] && sleep 0.05 || true
    done
  fi
}

if [[ "$1" != "nix" ]]; then
  log "ERROR: expected 'nix' as first argument, got '$1'"
  exit 1
fi
shift

case "$1" in
  build)
    shift

    flake_ref=""
    out_link=""
    print_out_paths=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --out-link)
          out_link="$2"
          shift 2
          ;;
        --print-out-paths)
          print_out_paths=true
          shift
          ;;
        --no-link|-L|--option)
          if [[ "$1" == "--option" ]]; then
            shift 2
          else
            shift
          fi
          ;;
        -*)
          shift
          ;;
        *)
          if [[ -z "$flake_ref" ]]; then
            flake_ref="$1"
          fi
          shift
          ;;
      esac
    done

    if [[ -z "$flake_ref" ]]; then
      log "ERROR: no flake reference provided"
      exit 1
    fi

    # Extract package name from flake ref (e.g., ".#kyaraben" -> "kyaraben")
    # If no # in the ref, it's a path-only flake ref, default to "kyaraben"
    if [[ "$flake_ref" == *"#"* ]]; then
      pkg_name="${flake_ref##*#}"
    else
      pkg_name="kyaraben"
    fi

    log "Building: $flake_ref (package: $pkg_name)"

    if [[ "$FAKE_NIX_FAIL" == "1" ]]; then
      log "Simulating build failure"
      echo "error: builder for '/nix/store/fake-hash-$pkg_name.drv' failed with exit code 1" >&2
      exit 1
    fi

    simulate_progress "$pkg_name"
    log "simulate_progress done"

    log "Creating fake store path..."
    fake_hash="$(echo "$pkg_name-$RANDOM" | md5sum | cut -c1-32)"
    store_path="/nix/store/$fake_hash-$pkg_name"
    log "fake_hash=$fake_hash store_path=$store_path"

    if [[ -n "$FAKE_NIX_STORE" ]]; then
      log "FAKE_NIX_STORE=$FAKE_NIX_STORE"
      real_store_path="$FAKE_NIX_STORE/$fake_hash-$pkg_name"
      log "Creating directories at $real_store_path"
      mkdir -p "$real_store_path/bin"
      mkdir -p "$real_store_path/lib/retroarch/cores"
      mkdir -p "$real_store_path/share/applications"
      mkdir -p "$real_store_path/share/icons/hicolor/256x256/apps"
      log "Directories created"

      # Create symlinks for binaries and cores specified via env vars
      # FAKE_NIX_BINARIES="es-de,retroarch,duckstation-qt"
      # FAKE_NIX_CORES="mgba_libretro.so,bsnes_libretro.so"
      if [[ -n "$FAKE_NIX_BINARIES" ]]; then
        IFS=',' read -ra bins <<< "$FAKE_NIX_BINARIES"
        for bin in "${bins[@]}"; do
          ln -sf "/nix/store/fake-wrapped/bin/$bin" "$real_store_path/bin/$bin"
        done
      fi

      if [[ -n "$FAKE_NIX_CORES" ]]; then
        IFS=',' read -ra cores <<< "$FAKE_NIX_CORES"
        for core in "${cores[@]}"; do
          ln -sf "/nix/store/fake-cores/$core" "$real_store_path/lib/retroarch/cores/$core"
        done
      fi

      log "Created fake store at: $real_store_path"

      if [[ -n "$out_link" ]]; then
        mkdir -p "$(dirname "$out_link")"
        ln -sfn "$real_store_path" "$out_link"
        log "Created symlink: $out_link -> $real_store_path"
      fi
    fi

    if [[ "$print_out_paths" == true ]]; then
      echo "$store_path"
    fi

    log "Build complete: $store_path"
    ;;

  --version)
    echo "nix (Nix) 2.18.1 (fake)"
    ;;

  flake)
    shift
    case "$1" in
      update)
        log "Fake flake update"
        ;;
      show)
        log "Fake flake show"
        echo '{}'
        ;;
      *)
        log "Unknown flake subcommand: $1"
        ;;
    esac
    ;;

  eval)
    shift
    echo '{}'
    ;;

  *)
    log "Unknown command: $1"
    exit 1
    ;;
esac
