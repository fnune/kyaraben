{
  "name": "kyaraben-ui",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "build": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:e2e": "playwright test",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.kyaraben.app",
    "productName": "Kyaraben",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "dist-electron/**/*"],
    "extraResources": [
      {
        "from": "src-tauri/binaries/",
        "to": "binaries/",
        "filter": ["kyaraben-*", "nix-portable-*"]
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Game",
      "maintainer": "Kyaraben Developers"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.games"
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@playwright/test": "^1",
    "@types/node": "^22",
    "electron": "^40",
    "electron-builder": "^25",
    "typescript": "^5",
    "vite": "^5"
  },
  "dependencies": {}
}
