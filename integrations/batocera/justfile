set quiet

default:
    @just --list

build:
    go build -o dist/kyaraben-batocera ./cmd/kyaraben-batocera

build-all:
    mkdir -p dist
    GOOS=linux GOARCH=amd64 go build -o dist/kyaraben-batocera-amd64 ./cmd/kyaraben-batocera
    GOOS=linux GOARCH=arm64 go build -o dist/kyaraben-batocera-arm64 ./cmd/kyaraben-batocera
    GOOS=linux GOARCH=arm GOARM=7 go build -o dist/kyaraben-batocera-arm ./cmd/kyaraben-batocera

test:
    go test ./...

lint:
    golangci-lint run ./...

check: lint test

clean:
    rm -rf dist
