# Kyaraben development container with Go
# Build: podman build -t kyaraben-dev -f Containerfile.dev .
# Run:   podman run -it --rm -v "$(pwd):/workspace:Z" kyaraben-dev

FROM docker.io/library/debian:bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    xz-utils \
    git \
    sudo \
    make \
    just \
    && rm -rf /var/lib/apt/lists/*

# Create dev user
RUN useradd -m -s /bin/bash dev && \
    echo "dev ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER dev
WORKDIR /home/dev

# Install Go
ARG GO_VERSION=1.24.0
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" | sudo tar -C /usr/local -xzf -

ENV PATH="/usr/local/go/bin:${PATH}"

# Install golangci-lint
RUN /usr/local/go/bin/go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.5
ENV PATH="/home/dev/go/bin:${PATH}"

WORKDIR /workspace
CMD ["/bin/bash"]
